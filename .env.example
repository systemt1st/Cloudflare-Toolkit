# ===================
# 数据库配置
# ===================
DB_NAME=cf_toolkit
DB_USER=cftools
DB_PASSWORD=your_secure_password_here

# ===================
# Redis 配置
# ===================
REDIS_URL=redis://redis:6379/0

# ===================
# 安全配置
# ===================
# JWT 密钥 (使用 openssl rand -hex 32 生成)
JWT_SECRET=your_jwt_secret_key_here

# 加密密钥 (使用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成)
ENCRYPTION_KEY=your_fernet_key_here

# ===================
# 应用配置
# ===================
# 环境：dev / prod（默认按 prod 处理）
ENV=prod

# 是否强制 Cookie Secure（默认：dev=false，其它=true；本地 http 跑 prod 时可设为 false）
COOKIE_SECURE=

# 前端 API 地址（给浏览器访问用；使用 Nginx 反代 /api 时可留空走同源）
NEXT_PUBLIC_API_URL=http://localhost:8000

# 前端站点地址（用于邮件里的重置链接）
FRONTEND_BASE_URL=http://localhost:3000

# ===================
# 订阅/积分/限流（可选）
# ===================
# 免费用户每月积分
FREE_MONTHLY_CREDITS=1000
# 每条任务项消耗积分（成功/失败都扣）
CREDITS_PER_ITEM=10
# 批量接口限流（每分钟）
USER_BATCH_RATE_LIMIT=10
USER_BATCH_RATE_WINDOW_SECONDS=60

# ===================
# 数据库连接池（可选）
# ===================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ===================
# 监控（可选）
# ===================
# 启用后端 Prometheus 指标：/api/metrics
METRICS_ENABLED=true

# ===================
# Resend 邮件服务
# ===================
RESEND_API_KEY=re_xxxxx
# 生产环境请改为你在 Resend 验证过的发件人
RESEND_FROM=onboarding@resend.dev

# 密码重置 token 有效期（分钟）
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ===================
# Google OAuth
# ===================
# Google 登录需要配置（前后端都用同一个 Client ID）
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ===================
# Stripe 支付（订阅）
# ===================
# Stripe Secret Key：sk_test_... / sk_live_...
STRIPE_SECRET_KEY=
# Stripe Webhook Signing Secret：whsec_...
STRIPE_WEBHOOK_SECRET=
# 年费订阅 Price ID（建议 USD + yearly recurring）
STRIPE_PRICE_ID_YEARLY=
# 是否允许在 Stripe Checkout 使用优惠码
STRIPE_ALLOW_PROMO_CODES=false
